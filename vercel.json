{
  "rewrites": [
    { "source": "/api/admin/orders", "destination": "/api/admin?path=orders" },
    { "source": "/api/admin/crm", "destination": "/api/admin?path=crm" },
    { "source": "/api/admin/credits", "destination": "/api/admin?path=credits" },
    { "source": "/api/notify-print-order", "destination": "/api/notify?type=print-order" },
    { "source": "/api/notify-purchase", "destination": "/api/notify?type=purchase" },
    { "source": "/api/signup-check", "destination": "/api/signup?action=check" },
    { "source": "/api/record-signup", "destination": "/api/signup?action=record" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/generate-image.js": {
      "maxDuration": 60
    },
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/setup-db.js": {
      "maxDuration": 60
    },
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/notify.js": {
      "maxDuration": 30
    },
    "api/signup.js": {
      "maxDuration": 30
    }
  }
}
